# humanize-output configuration
# Copy this to .env and fill in your values

# ── API (OpenAI-compatible) ────────────────────────────────────────────────────
# Base URL of your OpenAI-compatible API (e.g. OpenAI, Gemini via openai-compat, etc.)
OPENAI_API_BASE=https://api.openai.com/v1

# API key
OPENAI_API_KEY=sk-your-key-here

# ── Telegram ──────────────────────────────────────────────────────────────────
# Your Telegram chat ID (find it via @userinfobot)
TELEGRAM_CHAT_ID=your-telegram-chat-id

# ── OpenClaw paths (defaults shown; override if your installation differs) ───
# OPENCLAW_AGENTS_DIR=/root/.openclaw/agents
# OPENCLAW_CONFIG_PATH=/root/.openclaw/openclaw.json
# OPENCLAW_GATEWAY_PORT=18789

# ── Models ────────────────────────────────────────────────────────────────────
# Primary model (default: gemini-3-flash)
# For concurrent racing, use comma-separated list: gemini-3-flash,gemini-2.5-flash
# HUMANIZE_PRIMARY_MODELS=gemini-3-flash

# Fallback models tried in order if all primaries fail (default: gemini-2.5-flash)
# HUMANIZE_FALLBACK_MODELS=gemini-2.5-flash

# ── Context ───────────────────────────────────────────────────────────────────
# Number of conversation rounds to feed as style context (default: 4)
# HUMANIZE_CONTEXT_N=4

# Max characters for the context block (default: 2000)
# HUMANIZE_CONTEXT_MAX_CHARS=2000

# Set to 0 to disable context reading entirely
# HUMANIZE_CONTEXT=1

# ── Persona names (for context display) ────────────────────���──────────────────
# Name shown for the AI persona in context (default: Assistant)
# HUMANIZE_PERSONA_NAME=Assistant

# Name shown for the user in context (default: User)
# HUMANIZE_USER_NAME=User

# ── Tuning ────────────────────────────────────────────────────────────────────
# Per-model timeout in milliseconds (default: 60000)
# HUMANIZE_TIMEOUT_MS=60000

# Sampling temperature (default: 0.5)
# HUMANIZE_TEMPERATURE=0.5
