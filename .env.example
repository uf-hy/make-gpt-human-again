# make-gpt-human-again configuration
# Copy this to .env and fill in your values

# ── AI API (OpenAI-compatible) ─────────────────────────────────────────────────
# Works with any OpenAI-compatible endpoint: OpenAI, Gemini, Qwen, local LLMs, etc.

OPENAI_API_KEY=sk-your-key-here
OPENAI_API_BASE=https://api.openai.com/v1

# Primary model (or comma-separated for concurrent racing — fastest wins)
# Recommended: Gemini 3 Flash (fast + free tier), Gemini 2.5 Flash (smart + free tier)
OPENAI_MODEL=gemini-2.0-flash

# Fallback models tried in order if all primaries fail (optional but recommended)
# HUMANIZE_FALLBACK_MODELS=gpt-4o

# ── Persona prompt ────────────────────────────────────────────────────────────
# Path to a custom system prompt file (optional)
# Defaults to prompts/humanize.txt (the fufu酱 catgirl persona)
# HUMANIZE_PROMPT_FILE=/path/to/your-persona.txt

# ── Tuning ────────────────────────────────────────────────────────────────────
# Per-model timeout in milliseconds (default: 60000)
# HUMANIZE_TIMEOUT_MS=60000

# Sampling temperature (default: 0.5)
# HUMANIZE_TEMPERATURE=0.5

# ── OpenClaw Integration (optional) ───────────────────────────────────────────
# Only needed if you're using this with OpenClaw (https://github.com/openclaw/openclaw)
# The OpenClaw skill version (humanize-output) adds auto-send + context injection

# Your Telegram chat ID (find via @userinfobot)
# TELEGRAM_CHAT_ID=your-chat-id

# OpenClaw paths (defaults shown; override if your installation differs)
# OPENCLAW_AGENTS_DIR=/root/.openclaw/agents
# OPENCLAW_CONFIG_PATH=/root/.openclaw/openclaw.json
# OPENCLAW_GATEWAY_PORT=18789
